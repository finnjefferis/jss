# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude/

# agents / marketing
.agents/
/public/marketing/

# docs & data not needed for the site
*.md
*.csv
*.tsv

# linkedin post assets
/linkedin-posts/

# captured site screenshots (before/after)
/public/ivyold*.png
/public/ivynew*.png
/public/ivyold-desktop.png
/public/ivy-google-reviews.png
